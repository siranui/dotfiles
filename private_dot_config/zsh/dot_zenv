# 環境変数の設定

# Languages
export LANG="ja_JP.UTF-8"

# History
export HISTFILE="$XDG_STATE_HOME"/zsh/history
export HISTSIZE=10000
export SAVEHIST=10000

# less
export LESSHISTFILE="$XDG_STATE_HOME"/less/history

# Default Editor
export EDITOR='nvim'
export VISUAL='nvim'

# # NPM
# export NPM_CONFIG_USERCONFIG="$XDG_CONFIG_HOME/npm/config"
# export NPM_CONFIG_CACHE="$XDG_CACHE_HOME/npm"
# export NPM_CONFIG_PROGRESS=false

# nodebrew (mise 移行のためコメントアウト)
# export NODEBREW_DIR="$HOME/.nodebrew"

# Android
export ANDROID_HOME="$HOME/Library/Android/sdk"
export ANDROID_USER_HOME="$XDG_DATA_HOME/android"
export GRADLE_USER_HOME="$XDG_DATA_HOME/gradle"
export GRADLE_HOME="/Applications/Android Studio.app/Contents/gradle/gradle-3.2"

# AWS CLI
export AWS_SHARED_CREDENTIALS_FILE="$XDG_CONFIG_HOME/aws/credentials"
export AWS_CONFIG_FILE="$XDG_CONFIG_HOME/aws/config"

# Python History
export PYTHONSTARTUP="$XDG_CONFIG_HOME/python/pythonrc"

# Babel
export BABEL_CACHE_PATH="$XDG_CACHE_HOME/babel/babel.json"
export NODE_REPL_HISTORY="$XDG_CACHE_HOME/node/repl_history"

# Docker
export DOCKER_CONFIG="$XDG_CONFIG_HOME"/docker

# Postgres
export PSQL_HISTORY="$XDG_CACHE_HOME/psql/history"

# MySQL
export  MYSQL_HISTFILE="$XDG_CACHE_HOME/mysql/history"

# Golang
export GOPATH="$XDG_CACHE_HOME/go"

# for NVIM
export NVIM_PYTHON_LOG_FILE="/tmp/log"
export NVIM_PYTHON_LOG_LEVEL="DEBUG"

# for TMUX
# export TMUX_PLUGIN_MANAGER_PATH="~/.local/share/tmux/plugins"
# set -g @plugin 'tmux-plugins/tmp'
# run "${TMUX_PLUGIN_MANAGER_PATH}/tpm/tpm"

# for Rust
export CARGO_HOME="$XDG_DATA_HOME"/cargo
export RUSTUP_HOME="$XDG_DATA_HOME"/rustup

# antigravity
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# LM Studio
export PATH="$HOME/.lmstudio/bin:$PATH"

# Hermes Agent — ensure ~/.local/bin is on PATH
export PATH="$HOME/.local/bin:$PATH"

# PATHs
path=(
  $HOME/.local/bin
  /usr/local/{bin,sbin}
  $ANDROID_HOME/tools
  $ANDROID_HOME/platform-tools
  $XDG_DATA_HOME/bin
  $XDG_CACHE_HOME/go/bin
  $HOME/go/bin
  $HOME/miniconda3/bin
  $DOCKER_CONFIG/bin
  $CARGO_HOME/bin
  $RUSTUP_HOME/bin
  $path
)

eval "$(/opt/homebrew/bin/brew shellenv zsh)"

eval "$(mise activate zsh)"

fpath=($(brew --prefix)/share/zsh/site-functions $fpath)
typeset -gU cdpath fpath mailpath path
